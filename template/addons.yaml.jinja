# Addon repos cloned + symlinked by `nix run .#update-repos` (Part 2).
#
# Two entry formats:
#   repo-key:              # tracks branch ENV.ODOO_VERSION
#     - "module_a"         # symlink only these modules ('*' = all)
#   repo-key:              # pinned to an exact commit
#     revision: <full 40-char sha>
#     modules:
#       - "module_a"
#
# Repo URL = ENV.DEFAULT_REPO_PATTERN with '{}' replaced by the repo key.
# A matching SSH deploy key at ~/.ssh/<repo-key> is used automatically.
ENV:
  DEFAULT_REPO_PATTERN: "{{ default_repo_pattern }}"
  ODOO_VERSION: "{{ odoo_version }}"
{% if use_queue_job %}

queue:
  - "queue_job"
  - "queue_job_cron"
{% endif %}
# web:
#   - "web_responsive"
{% if custom_repo_name %}

---
ENV:
  DEFAULT_REPO_PATTERN: "{{ custom_repo_pattern }}"
  ODOO_VERSION: "{{ odoo_version }}"

{{ custom_repo_name }}:
  - "*"
{% endif %}
