    </field>
</record>
```

## XML Search View

```xml
<record id="{{ module_prefix }}_model_view_search" model="ir.ui.view">
    <field name="name">{{ module_prefix }}.model.view.search</field>
    <field name="model">{{ module_prefix }}.model</field>
    <field name="arch" type="xml">
        <search>
            <field name="name" filter_domain="[('name', 'ilike', self)]"/>
            <field name="partner_id"/>
            <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
            <filter string="Group by Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
        </search>
    </field>
</record>
```

## View Inheritance

```xml
<record id="sale_order_view_form_inherit_{{ module_prefix }}" model="ir.ui.view">
    <field name="name">sale.order.view.form.inherit.{{ module_prefix }}_module</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='partner_id']" position="after">
            <field name="custom_field"/>
        </xpath>
    </field>
</record>
```

