## Security — Record Rules

```xml
<record id="{{ module_prefix }}_model_rule_company" model="ir.rule">
    <field name="name">{{ project_name }} Model: multi-company</field>
    <field name="model_id" ref="model_{{ module_prefix }}_model"/>
    <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
</record>
```

## ORM Patterns

```python
# Search with domain
records = self.env['sale.order'].search([('state', '=', 'sale')], limit=10, order='date_order desc')

# Search count (faster than search + len)
count = self.env['product.product'].search_count([('active', '=', True)])

# Recordset operations
active = partners.filtered(lambda p: p.active and p.email)
emails = partners.mapped('child_ids.email')
sorted_orders = orders.sorted(key=lambda o: o.amount_total, reverse=True)

# Aggregation (use read_group instead of Python-side sums)
grouped = self.env['sale.order.line'].read_group(
    [('order_id.state', '=', 'sale')], ['product_id', 'price_subtotal:sum'], ['product_id'])

# Batch create (NOT in a loop)
self.env['{{ module_prefix }}.model'].create([{'name': f'Record {i}'} for i in range(10)])
# Batch write
records.write({'state': 'confirmed'})
```

## Inheritance Patterns

```python
# Extension (adds fields/methods)
class SaleOrder(models.Model):
    _inherit = 'sale.order'
    custom_field = fields.Char()

# Delegation (composition via FK)
class ResUsers(models.Model):
    _name = 'res.users'
    _inherits = {'res.partner': 'partner_id'}
```

## Wizard Template

```python
class {{ project_name }}Wizard(models.TransientModel):
    _name = '{{ module_prefix }}.wizard'
    _description = '{{ project_name }} Wizard'

    date_from = fields.Date(required=True)
    date_to = fields.Date(required=True)

    def action_process(self):
        self.ensure_one()
        active_ids = self.env.context.get('active_ids', [])
        records = self.env['{{ module_prefix }}.model'].browse(active_ids)
        records.filtered(lambda r: r.state == 'draft').write({'state': 'confirmed'})
        return {'type': 'ir.actions.act_window_close'}
```

## Cron Template

```xml
<record id="ir_cron_cleanup" model="ir.cron">
    <field name="name">{{ project_name }}: Cleanup old records</field>
    <field name="model_id" ref="model_{{ module_prefix }}_model"/>
    <field name="state">code</field>
    <field name="code">model._cron_cleanup()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">days</field>
    <field name="numbercall">-1</field>
</record>
```

## Report Template (QWeb)

```xml
<template id="report_{{ module_prefix }}_document">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2><span t-field="o.name"/></h2>
                    <table class="table table-sm">
                        <thead><tr><th>Product</th><th class="text-end">Qty</th><th class="text-end">Price</th></tr></thead>
                        <tbody>
                            <tr t-foreach="o.line_ids" t-as="line">
                                <td><span t-field="line.product_id.name"/></td>
                                <td class="text-end"><span t-field="line.quantity"/></td>
                                <td class="text-end"><span t-field="line.price_unit"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </t>
</template>
```

## Server Action Template

```xml
<record id="action_auto_confirm" model="ir.actions.server">
    <field name="name">Auto Confirm</field>
    <field name="model_id" ref="model_{{ module_prefix }}_model"/>
    <field name="state">code</field>
    <field name="code">
        for record in records:
            if record.state == 'draft':
                record.action_confirm()
    </field>
    <field name="binding_model_id" ref="model_{{ module_prefix }}_model"/>
    <field name="binding_view_types">list,form</field>
</record>
```

## Controller Template

```python
from odoo import http
from odoo.http import request

class {{ project_name }}Controller(http.Controller):
    @http.route('/{{ module_prefix }}/data', type='json', auth='user', methods=['POST'])
    def get_data(self, **kwargs):
        return request.env['{{ module_prefix }}.model'].search_read(
            [('state', '=', 'confirmed')], ['name', 'total_amount'], limit=50)

    @http.route('/{{ module_prefix }}/public', type='http', auth='public', website=True)
    def public_page(self, **kwargs):
        return request.render('{{ module_prefix }}_module.public_template', {})
```
