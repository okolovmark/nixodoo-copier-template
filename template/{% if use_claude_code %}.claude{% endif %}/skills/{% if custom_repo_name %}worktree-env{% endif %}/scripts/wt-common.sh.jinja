# shellcheck shell=bash
# shellcheck disable=SC2034  # vars are consumed by the sourcing wt-*.sh scripts
# Shared config + helpers for per-session pipeline worktree envs.
# Sourced by the wt-*.sh scripts — not run directly.
#
# Model: every parallel pipeline session gets its OWN isolated env —
#   worktree  .worktrees/<slug>/            (git checkout, the code)
#   runtime   .worktrees/_env/<slug>/       (odoo.conf, data_dir, port file)
#   DB        wt_<slug>                      (independent restore of the prod dump)
#   service   odoo-wt@<slug>.service         (own Odoo on its own port)
# Nothing is shared between sessions except the read-only seed dump and the
# pinned OCA/CE module sources. The user's main env (develop / odoo.service /
# {{ odoo_http_port }}) is never touched.

PROJ="${{ "{" }}{{ project_dir_var }}:-$HOME/{{ project_name }}}"
SRC_REPO="$PROJ/src/{{ custom_repo_name }}"               # nested addons repo (the user's main checkout)
MAIN_FARM="$PROJ/.local/share/Odoo/addons/{{ odoo_version }}"   # main symlink farm — source of truth for OCA/CE targets
SEED_FILESTORE="$PROJ/.local/share/Odoo/filestore/{{ db_name }}"  # best-effort attachment seed

WT_ROOT="$PROJ/.worktrees"                         # per-task git worktrees (gitignored)
WT_ENVROOT="$WT_ROOT/_env"                         # per-session runtime (conf/data/port)
BACKUP_DIR="$PROJ/backup"                           # prod seed dump lives here
LOCKFILE="$WT_ROOT/.wt.lock"                        # serializes port alloc + git worktree add

PORT_BASE=2700                                      # session http ports live in [2700, 2799]
PORT_MAX=2799

# Local postgres (odoo.conf: localhost:{{ postgres_port }}, odoo/odoo). The shared cluster is
# already up via postgres.service — we never pg_ctl it, only create/drop DBs.
export PGPASSWORD={{ db_password }}
PSQL="psql -h localhost -p {{ postgres_port }} -U {{ db_user }}"

WT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

db_name_for() { echo "wt_${1//-/_}"; }                                   # slug -> safe pg identifier
db_exists()   { $PSQL -d postgres -tAc "SELECT 1 FROM pg_database WHERE datname='$1'" | grep -q 1; }
